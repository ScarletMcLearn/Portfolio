---
import type { CollectionEntry } from 'astro:content';
import DisciplineBadge from './DisciplineBadge.astro';

interface Props {
  entry: CollectionEntry<'case-studies'>;
}
const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a
  href={`${base}work/${entry.data.discipline}/${entry.id}`}
  class="group hover:border-accent-500 flex h-full flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 transition-colors"
>
  <DisciplineBadge discipline={entry.data.discipline} class="self-start" />
  <h3 class="group-hover:text-accent-600 mt-3 text-lg font-semibold">{entry.data.title}</h3>
  <p class="mt-2 flex-1 text-sm text-[var(--text-muted)]">{entry.data.summary}</p>
  <span class="text-accent-600 mt-4 text-sm font-semibold">Read case study &rarr;</span>
</a>
