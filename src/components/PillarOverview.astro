---
import { withBase } from '../lib/url';

const pillars = [
  {
    href: withBase('/software-engineering'),
    title: 'Software Engineering',
    description:
      'Backend services, REST APIs, database design, and developer tooling — built to be maintainable, not just demoable.',
  },
  {
    href: withBase('/quality-engineering'),
    title: 'Quality Engineering',
    description:
      'Test architecture, automation platforms, API/performance safeguards, and CI/CD quality gates for complex products.',
  },
  {
    href: withBase('/data-science-ai'),
    title: 'Data Science & AI',
    description:
      'Applied machine learning, NLP, and predictive modeling across a sustained public practice spanning classical ML to LLMs.',
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-labelledby="pillars-heading">
  <h2 id="pillars-heading" class="sr-only">Three professional pillars</h2>
  <div class="grid gap-6 sm:grid-cols-3">
    {
      pillars.map((p) => (
        <a
          href={p.href}
          class="group hover:border-accent-500 flex flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6 transition-colors"
        >
          <h3 class="group-hover:text-accent-600 text-lg font-semibold">{p.title}</h3>
          <p class="mt-2 flex-1 text-sm text-[var(--text-muted)]">{p.description}</p>
          <span class="text-accent-600 mt-4 text-sm font-semibold">Learn more &rarr;</span>
        </a>
      ))
    }
  </div>
</section>
