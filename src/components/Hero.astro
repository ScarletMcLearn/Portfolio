---
import { profile } from '../data/profile';
import { socialLinks } from '../data/social';
import CTAButton from './CTAButton.astro';
import { withBase } from '../lib/url';

const githubLink = socialLinks.find((l) => l.icon === 'github');
const linkedinLink = socialLinks.find((l) => l.icon === 'linkedin');
const kaggleLink = socialLinks.find((l) => l.icon === 'kaggle');

const pathways = [
  { href: withBase('/software-engineering'), label: 'Explore Software Engineering' },
  { href: withBase('/quality-engineering'), label: 'Explore Quality Engineering' },
  { href: withBase('/data-science-ai'), label: 'Explore Data Science & AI' },
];
---

<section class="mx-auto max-w-6xl px-4 pt-16 pb-16 sm:px-6 sm:pt-24">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-accent-600 text-sm font-semibold tracking-wide uppercase">
      {profile.umbrellaTitle}
    </p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight sm:text-5xl">{profile.heroHeadline}</h1>
    <p class="mt-6 text-lg text-[var(--text-muted)] sm:text-xl">{profile.heroSubhead}</p>

    <p class="mt-4 text-sm text-[var(--text-muted)]">
      {profile.location} &middot; {profile.remote}
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <CTAButton href={withBase('/work')} variant="primary">View Case Studies</CTAButton>
      <CTAButton href={withBase('/resumes')} variant="secondary">View Resumes</CTAButton>
      <CTAButton href={withBase('/#contact')} variant="secondary">Contact Me</CTAButton>
    </div>

    <div class="mt-6 flex flex-wrap items-center justify-center gap-5 text-sm">
      {
        githubLink && (
          <a
            href={githubLink.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]"
          >
            GitHub
          </a>
        )
      }
      {
        linkedinLink && (
          <a
            href={linkedinLink.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]"
          >
            LinkedIn
          </a>
        )
      }
      {
        kaggleLink && (
          <a
            href={kaggleLink.url}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-[var(--text-muted)] hover:text-[var(--text)]"
          >
            Kaggle
          </a>
        )
      }
    </div>
  </div>

  <div class="mx-auto mt-14 grid max-w-4xl gap-4 sm:grid-cols-3">
    {
      pathways.map((p) => (
        <a
          href={p.href}
          class="hover:border-accent-500 hover:text-accent-600 rounded-xl border border-[var(--border)] bg-[var(--surface)] p-5 text-center text-sm font-semibold transition-colors"
        >
          {p.label}
        </a>
      ))
    }
  </div>
</section>
