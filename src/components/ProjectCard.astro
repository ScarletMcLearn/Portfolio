---
import type { DataScienceProject } from '../data/types';

interface Props {
  project: DataScienceProject;
}
const { project } = Astro.props;
---

<div class="flex h-full flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6">
  <span
    class="self-start rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] px-3 py-1 text-xs font-semibold text-[var(--text-muted)]"
  >
    {project.category}
  </span>
  <h3 class="mt-3 text-lg font-semibold">{project.title}</h3>
  <p class="mt-2 text-sm text-[var(--text-muted)]">{project.datasetContext}</p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {
      project.techniques.map((t) => (
        <span class="rounded-md bg-[var(--bg-subtle)] px-2 py-1 text-xs font-medium">{t}</span>
      ))
    }
  </div>

  <p class="mt-4 text-xs text-[var(--text-muted)]">
    <strong class="font-semibold">Evaluation:</strong>
    {project.evaluationApproach}
  </p>
  <p class="mt-2 text-xs text-[var(--text-muted)]">
    <strong class="font-semibold">Limitations:</strong>
    {project.limitations}
  </p>

  <div class="mt-4 flex-1"></div>

  <div class="mt-4 flex flex-wrap gap-3">
    {
      project.sourceLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-accent-600 text-sm font-semibold hover:underline"
        >
          {link.label} &rarr;
        </a>
      ))
    }
  </div>
</div>
