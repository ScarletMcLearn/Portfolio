---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  id?: string;
}
const { eyebrow, title, description, id } = Astro.props;
---

<div class="mx-auto max-w-2xl text-center">
  {
    eyebrow && (
      <p class="text-accent-600 text-sm font-semibold tracking-wide uppercase">{eyebrow}</p>
    )
  }
  <h2 id={id} class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-lg text-[var(--text-muted)]">{description}</p>}
</div>
