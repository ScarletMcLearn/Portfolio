---
interface Props {
  size?: number;
  class?: string;
}
const { size = 48, class: className = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="SSE monogram"
  class={className}
>
  <rect width="48" height="48" rx="10" class="fill-accent-600"></rect>
  <text
    x="50%"
    y="54%"
    text-anchor="middle"
    dominant-baseline="middle"
    font-family="ui-sans-serif, system-ui, sans-serif"
    font-size="18"
    font-weight="700"
    fill="white"
    letter-spacing="0.5">SSE</text
  >
</svg>
