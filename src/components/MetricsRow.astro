---
const metrics = [
  { label: '11+ years in engineering and quality', value: '11+' },
  { label: 'Software, quality, and data disciplines', value: '3' },
  { label: 'International distributed-team experience', value: 'BD · UAE · CA · US' },
  { label: 'Reported automation improvements of up to 80%', value: 'Up to 80%' },
];
---

<section
  class="border-y border-[var(--border)] bg-[var(--bg-subtle)]"
  aria-label="Credibility metrics"
>
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-6 px-4 py-10 sm:px-6 lg:grid-cols-4">
    {
      metrics.map((m) => (
        <div class="text-center">
          <p class="text-accent-600 text-2xl font-bold sm:text-3xl">{m.value}</p>
          <p class="mt-1 text-xs text-[var(--text-muted)] sm:text-sm">{m.label}</p>
        </div>
      ))
    }
  </div>
</section>
