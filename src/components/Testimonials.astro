---
import { testimonials } from '../data/testimonials';
import SectionHeading from './SectionHeading.astro';
---

{
  testimonials.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-labelledby="testimonials-heading">
      <SectionHeading
        id="testimonials-heading"
        eyebrow="Testimonials"
        title="What colleagues say"
      />
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((t) => (
          <blockquote class="rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6">
            <p class="text-sm italic">&ldquo;{t.quote}&rdquo;</p>
            <footer class="mt-4 text-sm">
              <p class="font-semibold">{t.name}</p>
              <p class="text-[var(--text-muted)]">
                {t.title}, {t.company}
              </p>
            </footer>
          </blockquote>
        ))}
      </div>
    </section>
  )
}
