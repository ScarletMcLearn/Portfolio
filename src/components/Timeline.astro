---
import { experience } from '../data/experience';
import DisciplineBadge from './DisciplineBadge.astro';
---

<ol class="mx-auto max-w-3xl space-y-8 border-l border-[var(--border)] pl-6">
  {
    experience.map((role) => (
      <li class="relative">
        <span class="bg-accent-500 absolute top-1.5 -left-[1.65rem] h-3 w-3 rounded-full" />
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
          <h3 class="font-semibold">{role.role}</h3>
          <span class="text-xs text-[var(--text-muted)]">
            {role.startDate} &ndash; {role.endDate}
          </span>
        </div>
        <p class="text-sm text-[var(--text-muted)]">
          {role.company} &middot; {role.companyLocation}
        </p>
        <p class="mt-2 text-sm">{role.summary}</p>
        <div class="mt-3 flex flex-wrap gap-2">
          {role.disciplines.map((d) => (
            <DisciplineBadge discipline={d} />
          ))}
        </div>
      </li>
    ))
  }
</ol>
