---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { withBase } from '../lib/url';
---

<BaseLayout
  title="Page Not Found - Syed Shams Elahi"
  description="The page you're looking for doesn't exist."
>
  <section class="mx-auto flex max-w-xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <p class="text-accent-600 text-sm font-semibold tracking-wide uppercase">404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">Page not found</h1>
    <p class="mt-4 text-[var(--text-muted)]">
      The page you're looking for doesn't exist or may have moved.
    </p>
    <CTAButton href={withBase('/')} variant="primary" class="mt-8"> Back to home </CTAButton>
  </section>
</BaseLayout>
