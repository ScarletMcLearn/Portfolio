---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import { resumeVariants } from '../data/resumes';
---

<BaseLayout
  title="Résumés — Syed Shams Elahi"
  description="Three role-focused résumés for Syed Shams Elahi: software engineering, quality engineering/SDET, and data science & AI."
>
  <section class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 sm:py-24">
    <SectionHeading
      eyebrow="Résumés"
      title="Choose the résumé that fits the role"
      description="I work across three connected disciplines. Each résumé leads with the experience most relevant to that role family — pick whichever matches what you're hiring for."
    />
  </section>

  <section class="mx-auto max-w-4xl px-4 pb-24 sm:px-6">
    <div class="grid gap-6 sm:grid-cols-3">
      {
        resumeVariants.map((resume) => (
          <div class="flex flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] p-6">
            <h2 class="text-lg font-semibold">{resume.label}</h2>
            <p class="text-accent-600 mt-2 text-sm font-medium">{resume.bestFor}</p>
            <p class="mt-3 flex-1 text-sm text-[var(--text-muted)]">{resume.description}</p>
            <CTAButton
              href={`${import.meta.env.BASE_URL}resume/${resume.filename}`}
              variant="primary"
              class="mt-6"
            >
              Download PDF
            </CTAButton>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
