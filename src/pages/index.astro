---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MetricsRow from '../components/MetricsRow.astro';
import PillarOverview from '../components/PillarOverview.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import SkillGroupCard from '../components/SkillGroupCard.astro';
import Timeline from '../components/Timeline.astro';
import Testimonials from '../components/Testimonials.astro';
import CTAButton from '../components/CTAButton.astro';
import { profile, aboutParagraphs } from '../data/profile';
import { skillGroups } from '../data/skills';
import { achievements } from '../data/achievements';
import { problemsICanSolve, collaborationStrengths } from '../data/capabilities';
import { DISCIPLINES } from '../data/types';
import { withBase } from '../lib/url';

const allCaseStudies = await getCollection('case-studies');
const featured = allCaseStudies
  .filter((c) => c.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Syed Shams Elahi - Software Engineer, Principal SDET & Data Scientist"
  description="Software Engineer, Principal SDET, and Data Scientist with 11+ years across backend engineering, automation architecture, API/performance quality, and applied machine learning."
>
  <Hero />
  <MetricsRow />
  <PillarOverview />

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-labelledby="work-heading">
    <SectionHeading
      id="work-heading"
      eyebrow="Selected Work"
      title="Multidisciplinary case studies"
      description="A sample spanning all three disciplines. See the full set on the Work page."
    />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((entry) => <CaseStudyCard entry={entry} />)}
    </div>
    <div class="mt-8 text-center">
      <CTAButton href={withBase('/work')} variant="secondary">View all case studies</CTAButton>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-labelledby="achievements-heading">
    <SectionHeading id="achievements-heading" eyebrow="Impact" title="Achievements" />
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        (['software-engineering', 'quality-engineering', 'data-science-ai'] as const).map((d) => (
          <div>
            <h3 class="text-accent-600 font-semibold">{DISCIPLINES[d].label}</h3>
            <ul class="mt-3 space-y-3">
              {achievements
                .filter((a) => a.discipline === d)
                .map((a) => (
                  <li>
                    <p class="text-sm font-semibold">{a.title}</p>
                    <p class="text-sm text-[var(--text-muted)]">{a.description}</p>
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section
    id="experience"
    class="mx-auto max-w-6xl px-4 py-16 sm:px-6"
    aria-labelledby="experience-heading"
  >
    <SectionHeading id="experience-heading" eyebrow="Experience" title="Career timeline" />
    <div class="mt-10">
      <Timeline />
    </div>
  </section>

  <section
    id="expertise"
    class="mx-auto max-w-6xl px-4 py-16 sm:px-6"
    aria-labelledby="expertise-heading"
  >
    <SectionHeading
      id="expertise-heading"
      eyebrow="Expertise"
      title="Skills across three disciplines"
      description="Grouped by discipline, shown with equal weight, not a single overwhelming badge wall."
    />
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {skillGroups.map((group) => <SkillGroupCard group={group} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-labelledby="problems-heading">
    <SectionHeading
      id="problems-heading"
      eyebrow="How I Can Help"
      title="Problems I can help solve"
    />
    <div class="mt-10 grid gap-8 sm:grid-cols-3">
      {
        problemsICanSolve.map((group) => (
          <div>
            <h3 class="text-accent-600 font-semibold">{group.title}</h3>
            <ul class="mt-3 space-y-2 text-sm text-[var(--text-muted)]">
              {group.items.map((item) => (
                <li class="flex gap-2">
                  <span aria-hidden="true">&bull;</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6" aria-labelledby="collaboration-heading">
    <SectionHeading
      id="collaboration-heading"
      eyebrow="Collaboration Strengths"
      title="What I bring to engineering teams"
    />
    <ul class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        collaborationStrengths.map((s) => (
          <li class="flex items-start gap-2 text-sm">
            <span class="bg-accent-500 mt-1 h-1.5 w-1.5 shrink-0 rounded-full" aria-hidden="true" />
            <span>{s}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section id="about" class="mx-auto max-w-3xl px-4 py-16 sm:px-6" aria-labelledby="about-heading">
    <SectionHeading id="about-heading" eyebrow="About" title="How I approach engineering" />
    <div class="mt-8 space-y-4 text-[var(--text-muted)]">
      {aboutParagraphs.map((p) => <p>{p}</p>)}
    </div>
    <div class="mt-8 rounded-xl border border-[var(--border)] bg-[var(--bg-subtle)] p-5 text-sm">
      <p>
        <strong class="font-semibold">Education:</strong> BSc in Computer Science, Independent University,
        Bangladesh (2016-2019)
      </p>
      <p class="mt-1">
        <strong class="font-semibold">Languages:</strong> English (fluent), IELTS overall band 8.0
      </p>
    </div>
  </section>

  <Testimonials />

  <section
    id="contact"
    class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6"
    aria-labelledby="contact-heading"
  >
    <SectionHeading
      id="contact-heading"
      eyebrow="Contact"
      title="Let's talk"
      description="Open to software engineering, quality engineering, and data-science conversations."
    />
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <CTAButton href={`mailto:${profile.email}`} variant="primary">Email Me</CTAButton>
      <CTAButton href="https://linkedin.com/in/SyedElahi" variant="secondary" external
        >LinkedIn</CTAButton
      >
      <CTAButton href="https://github.com/ScarletMcLearn" variant="secondary" external
        >GitHub</CTAButton
      >
    </div>
  </section>
</BaseLayout>
