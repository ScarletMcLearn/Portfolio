{
  "name": "syed-shams-elahi-portfolio",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.23.1"
  },
  "scripts": {
    "dev": "set ASTRO_TELEMETRY_DISABLED=1&& astro dev",
    "build": "set ASTRO_TELEMETRY_DISABLED=1&& astro build",
    "preview": "set ASTRO_TELEMETRY_DISABLED=1&& astro preview",
    "astro": "set ASTRO_TELEMETRY_DISABLED=1&& astro",
    "typecheck": "set ASTRO_TELEMETRY_DISABLED=1&& astro check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.7",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "2.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript-eslint": "8.63.0",
    "typescript": "5.9.3"
  }
}
